{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    },
    "storybook": {
      "url": "http://localhost:6006/mcp"
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/jmtrs/IdeaProjects/aggc-ui/.claude/hooks/check-styled-system.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/jmtrs/IdeaProjects/aggc-ui/.claude/hooks/check-vue-styles.sh"
          }
        ]
      }
    ]
  },
  "worktree": {
    "symlinkDirectories": ["node_modules", "styled-system"]
  }
}
